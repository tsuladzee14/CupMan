<AnchorPane prefHeight="295.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.cupMan.DataBaseSetUpController">
   <children>
      <VBox fillWidth="false" layoutX="38.0" layoutY="42.0" prefHeight="192.0" prefWidth="192.0" spacing="10.0">
