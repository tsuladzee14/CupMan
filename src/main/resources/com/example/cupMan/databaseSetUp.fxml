            <Label prefHeight="20.0" prefWidth="70.0" text="User:">
               <font>
                  <Font name="System Bold" size="14.0" />
               </font>
            </Label>
            <TextField fx:id="userField" prefHeight="25.0" prefWidth="199.0" style="-fx-background-color: white; -fx-border-color: #ccc;" />
            <Label prefHeight="17.0" prefWidth="72.0" text="Password:">
               <font>
                  <Font name="System Bold" size="14.0" />
               </font>
            </Label>
            <PasswordField fx:id="passwordField" prefHeight="25.0" prefWidth="199.0" style="-fx-background-color: white; -fx-border-color: #ccc;" />
         </children>
      </VBox>
      <Button layoutX="264.0" layoutY="72.0" mnemonicParsing="false" onAction="#saveConfig" prefHeight="25.0" prefWidth="51.0" style="-fx-background-color: #4285f4; -fx-text-fill: white;" text="Save" />
   </children>
</AnchorPane>
