<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="anchorPane" prefHeight="664.0" prefWidth="1182.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.cupMan.FirstGameController">
   <children>
      <ImageView fitHeight="700.0" fitWidth="1240.0" layoutY="-2.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@../../../firstImage.png" />
         </image>
      </ImageView>
      <ImageView fx:id="cupManIV" fitHeight="88.0" fitWidth="94.0" layoutX="88.0" layoutY="516.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@../../../IdleCupMan.png" />
         </image>
      </ImageView>
      <ImageView fx:id="Boss" fitHeight="396.0" fitWidth="392.0" layoutX="834.0" layoutY="300.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@../../../Boss2.png" />
         </image>
      </ImageView>
      <ProgressBar fx:id="bossHPBar" layoutX="1017.0" layoutY="30.0" prefWidth="200.0" progress="0.0" style="-fx-border-color: red;" />
      <Label fx:id="WinLabel" alignment="CENTER" graphicTextGap="7.0" prefHeight="693.0" prefWidth="1240.0" text="YOU WIN!" textFill="#fbff00" visible="false">
         <font>
            <Font name="System Bold" size="96.0" />
         </font>
      </Label>
      <Button fx:id="menuButton" layoutY="-3.0" mnemonicParsing="false" onAction="#BackToMenu" prefHeight="151.0" prefWidth="169.0" style="-fx-background-color: red;" text="Back to main menu" textFill="#eeff00" visible="false">
         <font>
            <Font name="System Bold" size="14.0" />
         </font>
      </Button>
      <Label layoutX="943.0" layoutY="30.0" prefHeight="20.0" prefWidth="54.0" text="Boss HP:">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Label>
      <ProgressBar fx:id="cupManHPBar" layoutX="38.0" layoutY="31.0" prefWidth="200.0" progress="0.0" style="-fx-border-color: blue;" />
      <Label layoutX="257.0" layoutY="32.0" text=":Your HP">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Label>
      <Label fx:id="gameOverLabel" alignment="CENTER" prefHeight="699.0" prefWidth="1240.0" text="YOU LOSE!" textFill="RED" visible="false">
         <font>
            <Font size="96.0" />
         </font>
      </Label>
      <Label fx:id="countdownLabel" alignment="CENTER" prefHeight="693.0" prefWidth="1240.0" textFill="#e4e1e1" visible="false">
         <font>
            <Font name="System Bold" size="150.0" />
         </font>
      </Label>
   </children>
</AnchorPane>
